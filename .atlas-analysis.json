  "publicApiSurface": [
    "GET /coins/{mint} - Retrieve coin information",
    "GET /coins/latest - Get latest coins",
    "GET /coins/featured - Get featured coins",
    "POST /coins/create - Create new coin",
    "GET /trades/all/{mint} - Get all trades for a coin",
    "GET /trades/latest - Get latest trades",
    "POST /auth/login - Authenticate user",
    "GET /auth/my-profile - Get current user profile",
    "GET /users/{id} - Get user information",
    "POST /users/register - Register new user",
    "POST /bookmarks - Create bookmark",
    "GET /bookmarks - List bookmarks",
    "POST /likes/{targetId} - Like content",
    "DELETE /likes/{targetId} - Unlike content",
    "POST /following/{userId} - Follow user",
    "DELETE /following/{userId} - Unfollow user",
    "GET /livestreams/{mint} - Get livestream info",
    "POST /livestreams/create/livestream - Create livestream",
    "GET /notifications - Get user notifications",
    "GET /search - Search across platform",
    "GET /balances/{address} - Get wallet balances",
    "GET /candlesticks/{mint} - Get price candlestick data",
    "POST /reports - Submit content report",
    "GET /moderation/ban/users - List banned users"
  ]
